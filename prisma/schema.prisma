// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client-js"
  moduleFormat = "cjs" // 👈 OBLIGATORIO en Prisma 7 para NestJS
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// CENTRALIZACIÓN Y CONFIGURACIÓN
// ==========================================

model SystemConfiguration {
  id    String                  @id @default(uuid())
  key   SystemConfigurationKeys
  value String
}

enum SystemConfigurationKeys {
  MAX_MONTHLY_HOURS
  MIN_REST_HOURS
  ALLOW_DOUBLE_SHIFT
  DEFAULT_SHIFT_DURATION
  ENABLE_BIRTHDAY_DAY_OFF
  AUTO_APPROVE_SHIFT_CHANGES
  MAX_CONSECUTIVE_NIGHTS
}

model FeatureFlag {
  id           String      @id @default(uuid())
  feature_name FeaturTypes
  isActive     Boolean     @default(false)
}

enum FeaturTypes {
  AUTO_SCHEDULING
  SHIFT_SWAP_AUTOMATION
  AI_FATIGUE_ANALYSIS
  WHATSAPP_NOTIFICATIONS
  EMERGENCY__AI
  DARK_MODE
  MULTI_BRANCH_SUPPORT
}

model Organization {
  id                       String                    @id @default(uuid())
  name                     String
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  code                     String
  timezone                 String
  country                  String
  status                   String                    @default("A")
  settings                 OrganizationSetting?
  departments              Department[]
  users                    User[]
  shifts                   Shift[]
  rules                    WorkRule[]
  shiftTemplates           ShiftTemplate[]
  branches                 Branch[]
  roles                    Roles[]
  ruleGroups               RuleGroup[]
  monthlyDistributionRules MonthlyDistributionRule[]
  integrations             Integration[]
  notifications            Notification[]
  schedules                Schedule[]
  auditLogs                AuditLog[]
  nurses                   Nurse[]
  emergencyCoverages       EmergencyCoverages[]
  nursePreferences         NursePreferences[]
  optimizationScores       OptimizationScore[]
  scheduleEntries          ScheduleEntry[]
  absences                 Absence[]
  leaves                   Leave[]
  workLoadMetrics          WorkLoadMetrics[]
  nurseProfiles            NurseProfile[]
  nurseAvailabilities      NurseAvailability[]
  nurseRestrictions        NurseRestriction[]
  vacations                Vacation[]
  departmentConfigurations DepartmentConfiguration[]
  specialities             Speciality[]
  shiftChangeRequests      ShiftChangeRequest[]
  shiftChangeApprovals     ShiftChangeApprovals[]
  shiftChangeDocuments     ShiftChangeDocument[]
  notificationTypes        NotificationType[]
  notificationTemplates    NotificationTemplates[]

  @@map("organizations")
}

model OrganizationSetting {
  id             String @id @default(uuid())
  organizationId String @unique

  /**
   * |--------------------------------------------------------------------------
   * | GENERAL SETTINGS
   * |--------------------------------------------------------------------------
   */

  birthday_free_day_enabled Boolean @default(false)
  require_shift_approval    Boolean @default(false)
  auto_balance_nights       Boolean @default(true)
  allow_cross_department    Boolean @default(false)
  allow_overtime            Boolean @default(true)

  /**
   * |--------------------------------------------------------------------------
   * | HOURS LIMITS
   * |--------------------------------------------------------------------------
   */

  max_monthly_hours Int @default(160)
  max_weekly_hours  Int @default(44)
  overtime_limit    Int @default(20)

  /**
   * |--------------------------------------------------------------------------
   * | NIGHT LIMITS
   * |--------------------------------------------------------------------------
   */

  max_nights             Int @default(10)
  max_consecutive_nights Int @default(3)

  /**
   * |--------------------------------------------------------------------------
   * | FATIGUE SETTINGS
   * |--------------------------------------------------------------------------
   */

  minimum_rest_hours   Int @default(12)
  max_consecutive_days Int @default(6)

  /**
   * |--------------------------------------------------------------------------
   * | AUTOMATION
   * |--------------------------------------------------------------------------
   */

  auto_assign_emergency Boolean @default(false)
  auto_approve_swaps    Boolean @default(false)

  /**
   * |--------------------------------------------------------------------------
   * | SYSTEM
   * |--------------------------------------------------------------------------
   */

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /**
   * |--------------------------------------------------------------------------
   * | RELATIONS
   * |--------------------------------------------------------------------------
   */

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("organization_settings")
}

model Department {
  id                       String                    @id @default(uuid())
  name                     String
  organizationId           String
  code                     String                    @unique
  description              String
  organization             Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branchId                 String
  branch                   Branch                    @relation(fields: [branchId], references: [id])
  type                     DepartmentType
  criticalLevel            DepartmentCriticalLevel
  minimum_staff            Int                       @default(1)
  optimalStaff             Int                       @default(1)
  maxCapacity              Int
  allowOvertime            Boolean
  allowsCrossDepartment    Boolean                   @default(false)
  requiresSpecialization   Boolean                   @default(false)
  isEmergencyDepartment    Boolean                   @default(false)
  emergencyPriority        Int?                      @default(1)
  isActive                 Boolean                   @default(true)
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  users                    User[]
  shifts                   Shift[]
  shiftTemplates           ShiftTemplate[]
  monthlyDistributionRules MonthlyDistributionRule[]
  schedules                Schedule[]
  departmentSpecialities   DepartmentSpeciality[]
  departmentConfigurations DepartmentConfiguration[]
  operationalAlerts        OperationalAlert[]
  nurses                   Nurse[]
  emergencyCoverages       EmergencyCoverages[]

  @@map("departments")
}

enum DepartmentType {
  ICU
  ER
  PEDIATRICS
  SURGERY
  CARDIOLOGY
  RADIOLOGY
  ONCOLOGY
  MATERNITY
  LABORATORY
  TRAUMA
  INTERNAL_MEDICINE
  GENERAL
}

enum DepartmentCriticalLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model DepartmentSpeciality {
  departmentId  String
  department    Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  specialityId  String
  speciality    Speciality @relation(fields: [specialityId], references: [id], onDelete: Cascade)
  required      Boolean    @default(true)
  priority      Int        @default(1)
  minimum_staff Int?
  createdAt     DateTime   @default(now())

  @@id([departmentId, specialityId])
  @@map("department_specialties")
}

model DepartmentConfiguration {
  id                      String       @id @default(uuid())
  organizationId          String
  organization            Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  departmentId            String
  department              Department   @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  max_nights              Int
  minimum_staff_per_shift Int
  allow_externeal_support Boolean
  allow_double_shift      Boolean
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt

  @@map("department_configurations")
}

model OperationalAlert {
  id           String                 @id @default(uuid())
  departmentId String
  department   Department             @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  alertType    OperationalAlertyTypes
  severity     PriorityTypes
  status       OperationalAlertStatus @default(IN_PROGRESS)

  @@map("operational_alerts")
}

enum OperationalAlertStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  IGNORED
  ESCALATED
}

enum OperationalAlertyTypes {
  STAFF_SHORTAGE
  OVERTIME_RISK
  FATIGUE_RISK
  RULE_VIOLATION
  NO_NIGHT_COVERAGE
  MULTIPLE_ABSENCES
  OVERLOADED_NURSE
  UNBALANCED_DISTRIBUTION
  EMERGENCY_COVERAGE_REQUIRED
  EMERGENCY_COVERAGE_FAILED
  BURNOUT_CRITICAL
  STAFFING_SHORTAGE
}

model Schedule {
  id                String            @id @default(uuid())
  organizationId    String
  departmentId      String
  month             Int
  year              Int
  status            ScheduleStatus    @default(DRAFT)
  publishedAt       DateTime?
  publishedById     String?
  autoGenerated     Boolean           @default(false)
  optimizationScore Decimal?
  generationTimeMs  Int?
  hasConflicts      Boolean           @default(false)
  totalConflicts    Int               @default(0)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  organization      Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  department        Department        @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  publishedBy       User?             @relation(fields: [publishedById], references: [id])
  optimizationRuns  OptimizationRun[]
  scheduleVersions  ScheduleVersion[]
  scheduleEntries   ScheduleEntry[]

  @@unique([departmentId, month, year])
  @@map("schedules")
}

model ScheduleVersion {
  id            String   @id @default(uuid())
  scheduleId    String
  version       Int
  snapshot      Json
  createdById   String?
  createdBy     User?    @relation(fields: [createdById], references: [id])
  createdAt     DateTime @default(now())
  schedule      Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  changeSummary String?
  published     Boolean  @default(false)
  rollbackable  Boolean  @default(true)

  @@unique([scheduleId, version])
  @@map("schedule_versions")
}

enum ScheduleStatus {
  DRAFT
  GENERATING
  GENERATED
  UNDER_REVIEW
  APPROVED
  PUBLISHED
  ARCHIVED
  CANCELLED
}

model OptimizationRun {
  id         String   @id @default(uuid())
  scheduleId String
  schedule   Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  startedAt  DateTime
  fineshedAt DateTime
  result     Json

  @@map("optimization_runs")
}

model ScheduleEntry {
  id                  String              @id @default(uuid())
  scheduleId          String
  schedule            Schedule            @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  shiftId             String
  shift               Shift               @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  status              ScheduleEntryStatus @default(ASSIGNED)
  assignedById        String
  assignedBy          User                @relation(fields: [assignedById], references: [id], onDelete: Cascade)
  assignedAt          DateTime            @default(now())
  notes               String?
  isEmergencyCoverage Boolean             @default(false)
  optimizationScore   Decimal?
  date                DateTime
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  organizationId      String
  organization        Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  nurseId             String
  nurse               Nurse               @relation(fields: [nurseId], references: [id], onDelete: Cascade)

  @@map("schedule_entries")
}

enum ScheduleEntryStatus {
  ASSIGNED
  CONFIRMED
  PENDING
  CANCELLED
  REPLACED
}

model Nurse {
  id                  String                @id @default(uuid())
  userId              String
  user                User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  departmentId        String
  department          Department            @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  contract_type       ContracTypeList       @default(PERMANENT)
  hire_date           DateTime
  status              NurseStatusType       @default(ACTIVE)
  specialityId        String
  speciality          Speciality            @relation(fields: [specialityId], references: [id], onDelete: Cascade)
  absences            Absence[]
  nurseAvailabilities NurseAvailability[]
  workLoadMetrics     WorkLoadMetrics[]
  vacations           Vacation[]
  nurseRestrictions   NurseRestriction[]
  optimizationScores  OptimizationScore[]
  emergencyCandidates EmergencyCandidates[]
  organizationId      String
  organization        Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  emergencyCoverages  EmergencyCoverages[]
  nursePreferences    NursePreferences?
  scheduleEntries     ScheduleEntry[]
  nurseProfiles       NurseProfile[]

  @@map("nurses")
}

model Absence {
  id               String        @id @default(uuid())
  nurseId          String
  nurse            Nurse         @relation(fields: [nurseId], references: [id], onDelete: Cascade)
  organizationId   String
  organization     Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  date             DateTime
  endDate          DateTime      @default(now())
  type             AbsenceType
  status           AbsenceStatus @default(PENDING)
  reason           String
  reporterById     String
  approvedById     String?
  notes            String?
  requiresCoverage Boolean       @default(true)
  emergencyLevel   Int?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  reporter         User          @relation(fields: [reporterById], references: [id], onDelete: Cascade)
  approvedBy       User?         @relation("absence_approver", fields: [approvedById], references: [id])

  @@map("absences")
}

enum AbsenceType {
  SICKNESS
  EMERGENCY
  NO_SHOW
  VACATION
  MEDICAL_LICENSE
  PERSONAL
  UNJUSTIFIED
}

enum AbsenceStatus {
  PENDING
  APPROVED
  REJECTED
  COVERED
}

model NurseAvailability {
  id                    String                      @id @default(uuid())
  organizationId        String
  organization          Organization                @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  nurseId               String
  nurse                 Nurse                       @relation(fields: [nurseId], references: [id], onDelete: Cascade)
  date                  DateTime
  status                NurseAvailabilityStatusType
  shiftPreference       ShiftPreferenceType?
  availableForEmergency Boolean                     @default(false)
  availableForOvertime  Boolean                     @default(false)
  notes                 String?
  createdAt             DateTime                    @default(now())
  updatedAt             DateTime                    @updatedAt

  @@map("nurse_availability")
}

enum NurseAvailabilityStatusType {
  AVAILABLE
  PARTIAL
  NOT_AVAILABLE
}

enum ShiftPreferenceType {
  MORNING
  AFTERNOON
  NIGHT
  FLEXIBLE
}

model WorkLoadMetrics {
  id              String       @id @default(uuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  nurseId         String
  nurse           Nurse        @relation(fields: [nurseId], references: [id], onDelete: Cascade)
  total_hours     Decimal
  overtime_hours  Decimal
  month           Int
  year            Int
  regular_hours   Decimal
  nigth_hours     Decimal
  weekend_hours   Decimal
  holidy_hours    Decimal
  emergency_hours Decimal
  fatigue_score   Decimal
  fairness_score  Decimal
  workload_score  Decimal
  burnout_risk    Decimal
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@map("workload_metrics")
}

model Vacation {
  id              String         @id @default(uuid())
  organizationId  String
  organization    Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  nurseId         String
  nurse           Nurse          @relation(fields: [nurseId], references: [id], onDelete: Cascade)
  start_Date      DateTime
  end_Date        DateTime
  status          VacationStatus
  reason          String
  notes           String
  approvedById    String?
  approvedBy      User?          @relation(fields: [approvedById], references: [id])
  approvedAt      DateTime?
  rejectionReason String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@map("vacations")
}

enum VacationStatus {
  DRAFT
  PENDING_APPROVAL
  UNDER_REVIEW
  APPROVED
  PARTIALLY_APPROVED
  REJECTED
  CANCELLED
  EXPIRED
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  SUSPENSION
}

model NurseProfile {
  id                    String              @id @default(uuid())
  nurseId               String              @unique
  nurse                 Nurse               @relation(fields: [nurseId], references: [id], onDelete: Cascade)
  organizationId        String
  organization          Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  birthDate             DateTime
  emergencyContact      String
  emergencyContactPhone String
  educationLevel        EducationLevelTypes
  yearsOfExperience     Int?
  certifications        Json?
  languages             Json?
  notes                 String?
  health_restrictions   String
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  @@map("nurse_profiles")
}

model NurseRestriction {
  id                String                @id @default(uuid())
  organizationId    String
  organization      Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  nurseId           String
  nurse             Nurse                 @relation(fields: [nurseId], references: [id], onDelete: Cascade)
  restrictionType   NurseRestrictionType? @relation(fields: [restrictionTypeId], references: [id])
  restrictionTypeId String?
  startDate         DateTime?
  endDate           DateTime?
  notes             String?
  isTemporary       Boolean               @default(false)
  isActive          Boolean               @default(true)
  createdById       String?
  createdBy         User?                 @relation(fields: [createdById], references: [id])
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
}

model NurseRestrictionType {
  id                     String                       @id @default(uuid())
  code                   String                       @unique
  name                   NurseRestrictionTypes
  description            NurseRestrictionDescriptions
  severity               PriorityTypes
  affects_scheduler      Boolean
  affects_overtime       Boolean
  affects_nights         Boolean
  isSystem               Boolean
  isActive               Boolean
  createdAt              DateTime                     @default(now())
  updatedAt              DateTime                     @updatedAt
  restrictions           NurseRestriction[]
  nurseRestrictionTypeId String

  @@map("nurse_restrictions_types")
}

enum NurseRestrictionTypes {
  NO_NIGHT_SHIFTS
  ONLY_NIGHT_SHIFTS
  ONLY_DAY_SHIFTS
  ONLY_MORNING_SHIFTS
  ONLY_AFTERNOON_SHIFTS
  NO_WEEKENDS
  WEEKENDS_ONLY
  NO_HOLIDAYS
  NO_DOUBLE_SHIFTS
  NO_CONSECUTIVE_SHIFTS
  NO_CONSECUTIVE_NIGHTS
  LIMITED_CONSECUTIVE_DAYS
  LIMITED_HOURS
  NO_OVERTIME
  MAX_40_HOURS_WEEK
  MAX_8_HOURS_DAY
  REDUCED_WORKLOAD
  PART_TIME_ONLY
  PREGNANCY_RESTRICTION
  MEDICAL_RESTRICTION
  NO_HEAVY_PATIENTS
  NO_STANDING_LONG_HOURS
  FATIGUE_RECOVERY
  POST_SURGERY_LIMITATION
  TEMPORARY_HEALTH_LIMITATION
  CHRONIC_CONDITION
  MENTAL_HEALTH_RESTRICTION
  ONLY_ICU
  ONLY_ER
  ONLY_PEDIATRICS
  NO_ICU
  NO_ER
  NO_SURGERY
  RESTRICTED_DEPARTMENT_ACCESS
  UNDER_TRAINING
  SUPERVISION_REQUIRED
  NO_CRITICAL_PATIENTS
  JUNIOR_LIMITATION
  INTERN_RESTRICTION
  PROBATION_PERIOD
  UNION_RESTRICTION
  CONTRACT_LIMITATION
  TEMPORARY_EMPLOYEE
  AGENCY_STAFF_ONLY
  NO_EXTRA_SHIFTS
  FIXED_SCHEDULE_ONLY
  NO_EMERGENCY_COVERAGE
  LAST_MINUTE_UNAVAILABLE
  CANNOT_BE_ON_CALL
  RESTRICTED_MOBILITY
  NO_FLOATING
  HIGH_FATIGUE_RISK
  LABOR_LAW_LIMITATION
  MINIMUM_REST_REQUIRED
  MAX_MONTHLY_HOURS_REACHED
  LICENSE_RESTRICTION
  CERTIFICATION_EXPIRED
  TEMPORARY_AVAILABILITY
  VACATION_TRANSITION
  RETURNING_FROM_LEAVE
  RECENT_OVERTIME_BLOCK
  HIGH_RISK_PATIENT_RESTRICTION
  INFECTIOUS_AREA_RESTRICTION
  ISOLATION_AREA_RESTRICTION
  BIOHAZARD_LIMITATION
}

enum NurseRestrictionDescriptions {
  NO_PUEDE_HACER_AMANECIDAS
  SOLO_TRABAJA_NOCHES
  SOLO_TRABAJA_DIAS
  SOLO_MAÑANAS
  SOLO_TARDES
  NO_TRABAJA_FINES_DE_SEMANA
  SOLO_FINES_DE_SEMANA
  NO_TRABAJA_FERIADOS
  NO_PUEDE_HACER_DOBLE_TURNO
  NO_TURNOS_SEGUIDOS
  NO_NOCHES_CONSECUTIVAS
  MAXIMO_DIAS_SEGUIDOS
  HORAS_LIMITADAS
  NO_OVERTIME
  MAXIMO_40H
  MAXIMO_8H_POR_DIA
  CARGA_REDUCIDA
  SOLO_MEDIO_TIEMPO
  RESTRICCION_EMBARAZO
  RESTRICCION_MEDICA_GENERAL
  NO_PACIENTES_PESADOS
  NO_LARGAS_HORAS_DE_PIE
  RECUPERACION_FISICA
  RECUPERACION_CIRUGIA
  RESTRICCION_TEMPORAL
  CONDICION_CRONICA
  SALUD_MENTAL
  SOLO_UCI
  SOLO_EMERGENCIAS
  SOLO_PEDIATRIA
  NO_UCI
  NO_EMERGENCIAS
  NO_CIRUGIA
  ACCESO_LIMITADO
  EN_ENTRENAMIENTO
  REQUIERE_SUPERVISION
  NO_CRITICOS
  RESTRICCION_JUNIOR
  PASANTIA
  PERIODO_PRUEBA
  SINDICATO
  RESTRICCION_CONTRACTUAL
  TEMPORAL
  PERSONAL_EXTERNO
  NO_TURNOS_EXTRA
  HORARIO_FIJO
  NO_COBERTURA_URGENTE
  NO_DISPONIBILIDAD_URGENTE
  NO_GUARDIAS
  NO_MOVERSE_ENTRE_DEPARTAMENTOS
  NO_SOPORTE_CRUZADO
  ALTO_RIESGO_FATIGA
  RESTRICCION_LEGAL
  DESCANSO_OBLIGATORIO
  LIMITE_MENSUAL_ALCANZADO
  LICENCIA_LIMITADA
  CERTIFICACION_VENCIDA
  DISPONIBILIDAD_TEMPORAL
  CERCA_VACACIONES
  REINTEGRACION
  BLOQUEADA_POR_OVERTIME_RECIENTE
  NO_PACIENTES_ALTO_RISGO
  NO_AREAS_INFECCIOSAS
  NO_AISLAMIENTO
  RESTRICCION_BIOSEGURIDAD
}

enum EducationLevelTypes {
  ASSISTANT
  TECHNICIAN
  BACHELOR_DEGREE
  SPECIALIZATION
  MASTER_DEGREE
  DOCTORATE
}

model OptimizationScore {
  id               String       @id @default(uuid())
  nurseId          String
  nurse            Nurse        @relation(fields: [nurseId], references: [id], onDelete: Cascade)
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  fairness_score   Decimal
  fatigue_score    Decimal
  workload_score   Decimal
  overtime_score   Decimal?
  preference_score Decimal?
  overall_score    Decimal?
  calculatedAt     DateTime     @default(now())
  metadata         Json?

  @@map("optimization_scores")
}

model Speciality {
  id                     String                 @id @default(uuid())
  name                   String
  organizationId         String
  organization           Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  code                   String
  description            String
  departmentSpecialities DepartmentSpeciality[]
  nurses                 Nurse[]
  isActive               Boolean                @default(true)
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt

  @@map("specialities")
}

enum NurseStatusType {
  ACTIVE
  INACTIVE
  VACATION
  LICENSE
  SUSPENDED
}

enum ContracTypeList {
  PERMANENT
  TEMPORAL
  PER_DIEM
  PART_TIME
}

model Branch {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  address        String
  departments    Department[]
  city           String
  state          String
  country        String
  zipCode        String
  phone          String
  email          String
  latitude       Decimal
  longitude      Decimal
  timezone       String?      @default("UTC")
  isMainBranch   Boolean      @default(false)
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("branches")
}

model MonthlyDistributionRule {
  id             String                      @id @default(uuid())
  organizationId String
  organization   Organization                @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  departmentId   String
  department     Department                  @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  type           MonthlyDistributionRuleType
  configuration  Json

  @@map("monthly_distribution_rules")
}

enum MonthlyDistributionRuleType {
  BALANCE_NIGHTS
  BALANCE_WEEKENDS
  LIMIT_OVERTIME
  ROTATE_HOLIDAYS
  FAIRNESS_PRIORITY
  DISTRIBUTE_NEW_STAFF
  ICU_ROTATION
}

model Integration {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  provider       ProviderList
  configuration  Json
  name           String?
  isActive       Boolean      @default(true)
  webhookLogs    WebhookLog[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("integrations")
}

enum ProviderList {
  TWILIO
  WHATSAPP
  GOOGLE_CALENDAR
  OUTLOOK
  SAP
  ORACLE_HR
  BIOMETRIC_SYSTEM
  SMTP
  FIREBASE
  SENDGRID
  SLACK
  WORKDAY
  OPENAI
  CUSTOM
}

model WebhookLog {
  id            String      @id @default(uuid())
  integrationId String
  integration   Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  payload       Json
  response      Json

  @@map("webhook_logs")
}

model Notification {
  id             String        @id @default(uuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  title          String
  message        String
  readedAt       DateTime?
  createdAt      DateTime      @default(now())
  priority       PriorityTypes
  data           Json

  @@map("notifications")
}

model NotificationType {
  id             String                    @id @default(uuid())
  code           String                    @unique
  name           String
  description    String?
  category       NotificationCategoryTypes
  priority       PriorityTypes
  templateId     String
  templae        NotificationTemplates     @relation(fields: [templateId], references: [id], onDelete: Cascade)
  icon           String
  channels       Json?
  isActive       Boolean                   @default(true)
  allowPush      Boolean                   @default(true)
  allowEmail     Boolean                   @default(true)
  allowSMS       Boolean                   @default(false)
  metadata       Json?
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
  deletedAt      DateTime?
  organization   Organization?             @relation(fields: [organizationId], references: [id])
  organizationId String?

  @@map("notification_types")
}

model NotificationTemplates {
  id                String                  @id @default(uuid())
  organizationId    String
  organization      Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name              String
  description       String
  channel           NotificationChannelType
  language          String                  @default("es")
  version           Int                     @default(1)
  code              String                  @unique
  titleTemplate     String
  bodyTemplate      String
  htmlTemplate      String
  variables         Json
  metadata          Json
  previewPayload    Json
  isActive          Boolean
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  deletedAt         DateTime?
  notificationTypes NotificationType[]

  @@map("notification_templates")
}

enum NotificationChannelType {
  EMAIL
  SMS
  PUSH
  WHATSAPP
  IN_APP
}

enum NotificationCategoryTypes {
  SCHEDULE_PUBLISHED
  SCHEDULE_UPDATED
  SCHEDULE_ASSIGNMENT
  SCHEDULE_REMOVED
  SCHEDULE_CONFLICT
  SCHEDULE_REMINDER
  SHIFT_CHANGE_REQUESTED
  SHIFT_CHANGE_APPROVED
  SHIFT_CHANGE_REJECTED
  SHIFT_CHANGE_CANCELLED
  SHIFT_CHANGE_EXPIRED
  SHIFT_CHANGE_REQUIRES_CONFIRMATION
  VACATION_REQUESTED
  VACATION_APPROVED
  VACATION_REJECTED
  VACATION_REMINDER
  VACATION_CONFLICT
  LEAVE_REQUESTED
  LEAVE_APPROVED
  LEAVE_REJECTED
  MEDICAL_DOCUMENT_REQUIRED
  EMERGENCY_SHIFT_NEEDED
  EMERGENCY_SHIFT_ASSIGNED
  COVERAGE_SHORTAGE
  COVERAGE_REQUEST
  BACKUP_STAFF_REQUIRED
  RULE_VIOLATION
  OVERTIME_WARNING
  NIGHT_SHIFT_LIMIT_REACHED
  REST_PERIOD_VIOLATION
  MONTHLY_HOUR_LIMIT_REACHED
  APPROVAL_REQUIRED
  APPROVAL_PENDING
  APPROVAL_COMPLETED
  APPROVAL_OVERDUE
  DOCUMENT_EXPIRING
  CREDENTIAL_EXPIRING
  CONTRACT_UPDATE
  POLICY_UPDATE
  SYSTEM_MAINTENANCE
  SECURITY_ALERT
  PASSWORD_CHANGED
  LOGIN_DETECTED
  SCHEDULE_OPTIMIZED
  FAIRNESS_ALERT
  FATIGUE_RISK_DETECTED
  STAFFING_PREDICTION_ALERT
}

enum PriorityTypes {
  LOW
  MEDIUM
  HIGH
  URGENT
  CRITICAL
  INFO
}

// ==========================================
// USUARIOS Y ROLES (ENFERMERÍA / SUPERVISIÓN)
// ==========================================

model User {
  id             String       @id @default(uuid())
  email          String       @unique
  password       String
  firstName      String
  lastName       String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  departmentId   String?
  department     Department?  @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  // Solicitudes de Cambio (Como solicitante o receptor)
  sentChangeRequests     ShiftChangeRequest[] @relation("RequesterNurse")
  receivedChangeRequests ShiftChangeRequest[] @relation("ReceiverNurse")
  approvedChangeRequests ShiftChangeRequest[] @relation("ApproverSupervisor")
  approvedLeavesRequest  Leave[]              @relation("LeavesApprover")
  absenceApprover        Absence[]            @relation("absence_approver")

  activityLogs ActivityLog[]
  roles        Roles?          @relation(fields: [rolesId], references: [id])
  rolesId      String?
  leaves       Leave[]         @relation("UserLeaves")
  auditLog     AuditLog[]
  notification Notification[]
  nurses       Nurse[]
  absences     Absence[]
  status       NurseStatusType
  refreshToken String          @default("")
  lastLoginAt  DateTime        @default(now())
  createdAt    DateTime        @default(now())

  requestedApprovals   ShiftChangeApprovals[] @relation("ApprovalRequester")
  processedApprovals   ShiftChangeApprovals[] @relation("ApprovalApprover")
  shiftChangeDocuments ShiftChangeDocument[]  @relation("UserDocuments")
  auditLogId           String
  scheduleEntries      ScheduleEntry[]
  nurseRestrictions    NurseRestriction[]
  vacations            Vacation[]
  schedules            Schedule[]
  scheduleVersions     ScheduleVersion[]
  uploadDocuments      ShiftChangeDocument[]  @relation("UploadedDocuments")

  @@map("users")
}

model AuditLog {
  id String @id @default(uuid())

  // 1. Relación con el Usuario (CORREGIDO: Eliminado el @unique)
  userId String? // Puesto como opcional por si hay acciones del sistema o antes del login
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  // 2. NUEVO: Relación con la Organización (Multi-tenancy)
  // Permite al ADMIN de un hospital ver solo la auditoría de su propia clínica
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  action ActionAuditLogTypes

  moduleId String
  module   Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  old_value Json @default("{}")
  new_value Json @default("{}") // Añadido default para evitar nulos accidentales

  // 3. NUEVOS: Campos de infraestructura y rastreo técnico
  ipAddress String? // Para saber la IP del enfermero/admin
  userAgent String? // Para identificar el navegador, app móvil o dispositivo
  requestId String? // Excelente práctica: Permite agrupar múltiples logs creados en una misma petición HTTP

  createdAt DateTime @default(now()) // Puedes quitar 'createdAt: new Date()' en tu TS, Prisma lo maneja solo

  @@map("audit_logs")
}

enum ActionAuditLogTypes {
  CREATE
  UPDATE
  DELETE
  APPROVE
  REJECT
  PUBLISH
  ASSIGN_SHIFT
  CANCEL_SHIFT
  AUTO_GENERATE
}

model Module {
  id          String     @id @default(uuid())
  code        String     @unique
  name        String
  description String
  category    String?
  version     String?
  icon        String?
  route       String?
  isCore      Boolean
  isSystem    Boolean
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  auditLogs   AuditLog[]

  @@map("modules")
}

model Roles {
  id              String            @id @default(uuid())
  name            String // E.g., "Senior Nurse", "Junior Nurse", "Auxiliar"
  organizationId  String
  organization    Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  users           User[]
  rolePermissions RolePermissions[]

  @@map("roles")
}

model RolePermissions {
  roleId      String
  roles       Roles      @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permisionId String
  permissions Permission @relation(fields: [permisionId], references: [id], onDelete: Cascade)

  @@id([roleId, permisionId])
  @@map("role_permissions")
}

model Permission {
  id              String            @id @default(uuid())
  name            String            @unique
  description     String
  rolePermissions RolePermissions[]

  @@map("permissions")
}

model NursePreferences {
  id                 String         @id @default(uuid())
  nurseId            String         @unique
  nurse              Nurse          @relation(fields: [nurseId], references: [id], onDelete: Cascade)
  organizationId     String
  organization       Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  preferredShift     PreferredShift @default(MORNING) // Mañana, Tarde, Noche
  avoid_shifts       PreferredShift @default(NIGHT)
  maxNigthsPerMonth  Int            @default(10)
  maxDaysPerMonth    Int            @default(15)
  preferredDaysOff   Int            @default(10)
  prefersWeekendsOff Boolean        @default(false)
  allowOvertime      Boolean        @default(true)
  notes              String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@map("nurse_preferences")
}

enum PreferredShift {
  MORNING
  AFTERNOON
  NIGHT
  MORNING_AFTERNOON
  MORNING_NIGHT
  NIGTH_AFTERNOON
}

// ==========================================
// CORE: GESTIÓN DE TURNOS (SHIFTS)
// ==========================================

model Shift {
  id                     String               @id @default(uuid())
  organizationId         String
  organization           Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name                   String
  code                   String               @unique
  type                   ShiftType
  startTime              DateTime
  endTime                DateTime
  durationHours          DateTime
  color                  String?
  department             Department?          @relation(fields: [departmentId], references: [id])
  departmentId           String?
  isNightShift           Boolean              @default(false)
  isEmergencyShift       Boolean              @default(false)
  requiresSpecialization Boolean              @default(false)
  allowsOvertime         Boolean              @default(true)
  minimumStaffRequired   Int                  @default(1)
  isActive               Boolean              @default(true)
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  changeRequestsAsSource ShiftChangeRequest[] @relation("SourceShift")
  changeRequestsAsTarget ShiftChangeRequest[] @relation("TargetShift")
  scheduleEntries        ScheduleEntry[]
  emergencyCoverages     EmergencyCoverages[]

  @@map("shifts")
}

enum ShiftType {
  MORNING
  AFTERNOON
  NIGHT
  FULL_DAY
  ON_CALL
  EMERGENCY
  WEEKEND
  HOLIDAY
}

model EmergencyCoverages {
  id                  String                  @id @default(uuid())
  department          Department?             @relation(fields: [departmentId], references: [id])
  departmentId        String?
  shiftId             String
  shift               Shift                   @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  date                DateTime
  priority            PriorityTypes
  status              EmergencyCoverageStatus
  emergencyCandidates EmergencyCandidates[]
  rank                Int?
  available           Boolean                 @default(true)
  fatigueRisk         Float?
  overtimeRisk        Float?
  compatibilityScore  Float?
  aiRecommendation    Json?
  selected            Boolean                 @default(false)
  nurseId             String
  nurse               Nurse                   @relation(fields: [nurseId], references: [id], onDelete: Cascade)
  organizationId      String
  organization        Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  createdById         String?

  @@map("emergency_coverages")
}

enum EmergencyCoverageStatus {
  OPEN
  MATCHING
  CANDIDATES_FOUND
  ASSIGNED
  ACCEPTED
  REJECTED
  CANCELLED
  EXPIRED
  COMPLETED
}

model EmergencyCandidates {
  id         String             @id @default(uuid())
  coverageId String
  coverage   EmergencyCoverages @relation(fields: [coverageId], references: [id], onDelete: Cascade)
  nurseId    String
  nurse      Nurse              @relation(fields: [nurseId], references: [id], onDelete: Cascade)
  score      Decimal
  available  Boolean            @default(true)
  selected   Boolean

  @@map("emergency_candidates")
}

model ShiftTemplate {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  departmentId   String
  department     Department   @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  name           String // E.g., "Turno Matutino Estándar"
  description    String
  configuration  Json
  startTime      String // Almacenado como "07:00"
  endTime        String // Almacenado como "15:00"
  color          String?
  isActive       Boolean      @default(true)
  autoAssignable Boolean      @default(true)
  priority       Int          @default(1)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("shift_templates")
}

// ==========================================
// FLUJO OPERACIONAL: SOLICITUDES DE CAMBIO
// ==========================================

model ShiftChangeRequest {
  id             String        @id @default(uuid())
  status         RequestStatus @default(AWAITING_OTHER_NURSE)
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Quién pide el cambio y a quién
  requesterId String
  requester   User    @relation("RequesterNurse", fields: [requesterId], references: [id])
  receiverId  String?
  receiver    User?   @relation("ReceiverNurse", fields: [receiverId], references: [id])

  // Turnos involucrados
  sourceShiftId String
  sourceShift   Shift   @relation("SourceShift", fields: [sourceShiftId], references: [id], onDelete: Cascade)
  targetShiftId String?
  targetShift   Shift?  @relation("TargetShift", fields: [targetShiftId], references: [id], onDelete: SetNull)

  // Aprobación del supervisor
  approverId       String?
  approver         User?     @relation("ApproverSupervisor", fields: [approverId], references: [id])
  supervisorNotes  String?
  autoApproved     Boolean   @default(false)
  emergencyRequest Boolean   @default(false)
  aiRiskScore      Float?
  aiRecommendation Json?
  expiresAt        DateTime?
  approvedAt       DateTime?
  rejectedAt       DateTime?

  reason               String?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  shiftChangeApprovals ShiftChangeApprovals[]
  shiftChangeDocuments ShiftChangeDocument[]

  @@map("shift_change_requests")
}

model ShiftChangeApprovals {
  id                   String               @id @default(uuid())
  organizationId       String
  organization         Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  shiftChangeRequestId String
  shiftChangeRequest   ShiftChangeRequest   @relation(fields: [shiftChangeRequestId], references: [id], onDelete: Cascade)
  requesterId          String
  requester            User                 @relation("ApprovalRequester", fields: [requesterId], references: [id])
  approverId           String?
  approver             User?                @relation("ApprovalApprover", fields: [approverId], references: [id])
  decision             ChangeApprovalsTypes @default(PENDING)
  level                Int                  @default(1)
  autoApproved         Boolean              @default(false)
  comments             String
  aiRecommendation     Json?
  approvedAt           DateTime?
  rejectedAt           DateTime?
  expiresAt            DateTime?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  @@map("shift_change_approvals")
}

model ShiftChangeDocument {
  id                   String                  @id @default(uuid())
  organizationId       String
  organization         Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  shiftChangeRequestId String
  shiftChangeRequest   ShiftChangeRequest      @relation(fields: [shiftChangeRequestId], references: [id], onDelete: Cascade)
  requesterId          String
  requester            User                    @relation("UserDocuments", fields: [requesterId], references: [id])
  uploadedById         String?
  uploadedBy           User?                   @relation("UploadedDocuments", fields: [uploadedById], references: [id])
  documentType         ShiftChangeDocumentType
  fileName             String
  documentUrl          String
  mimeType             String
  size                 Int
  description          String?
  verified             Boolean                 @default(false)
  verifiedById         String?
  verifiedAt           DateTime?
  expiresAt            DateTime?
  aiAnalysis           Json?
  metadata             Json?
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  deletedAt            DateTime?

  @@map("shift_change_documents")
}

enum ShiftChangeDocumentType {
  MEDICAL_CERTIFICATE
  EMERGENCY_JUSTIFICATION
  SUPERVISOR_APPROVAL
  LEGAL_DOCUMENT
  FATIGUE_REPORT
  INCIDENT_REPORT
  OTHER
}

enum ChangeApprovalsTypes {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  EXPIRED
}

enum RequestStatus {
  AWAITING_OTHER_NURSE
  REJECTED_BY_NURSE
  ACCEPTED_BY_NURSE
  UNDER_SUPVERSION
  APPROVED_BY_SUPERVISOR
  REJECTED_BY_SUPERVISOR
  REJECTED
  CANCELLED
  EXPIRED
  COMPLETED
  ROLLED_BACK
  CONFLIC_DETECTED
}

// ==========================================
// ALERTAS, REGLAS Y LOGS (DASHBOARD)
// ==========================================

model WorkRule {
  id                  String               @id @default(uuid())
  organizationId      String
  organization        Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  code                String // E.g., "RULE_MAX_NIGHTS"
  name                String
  type                WorkRuleTypes        @default(CONFIGURABLE)
  description         String?
  value               String // Parámetro dinámico para el validador
  isActive            Boolean              @default(true)
  workRuleConditions  WorkRuleConditions[]
  workRuleActions     WorkRuleActions[]
  ruleGroupAssigments RuleGroupAssigment[]

  @@map("work_rules")
}

enum WorkRuleTypes {
  HARD
  SOFT
  CONFIGURABLE
  EVENT
}

model WorkRuleConditions {
  id             String   @id @default(ulid())
  workRuleId     String
  workRules      WorkRule @relation(fields: [workRuleId], references: [id], onDelete: Cascade)
  condition_type String
  operator       String
  value          String
  logical_group  String?
  priority       Int      @default(1)
  enabled        Boolean  @default(true)
  createdAt      DateTime @default(now())

  @@map("work_rule_conditions")
}

model WorkRuleActions {
  id              String   @id @default(ulid())
  workRuleId      String
  workRules       WorkRule @relation(fields: [workRuleId], references: [id], onDelete: Cascade)
  action_type     String
  action_value    String
  priority        Int      @default(1)
  enabled         Boolean  @default(true)
  stop_execution  Boolean  @default(false)
  async_execution Boolean  @default(false)
  metadata        Json?
  createdAt       DateTime @default(now())

  @@map("work_rule_actions")
}

model RuleGroup {
  id             String               @id @default(uuid())
  organizationId String
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignments    RuleGroupAssigment[]
  name           String
  code           String
  description    String
  isActive       Boolean
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@map("rule_groups")
}

model RuleGroupAssigment {
  id          String    @id @default(uuid())
  workRuleId  String
  workRules   WorkRule  @relation(fields: [workRuleId], references: [id], onDelete: Cascade)
  ruleGroupId String
  ruleGroup   RuleGroup @relation(fields: [ruleGroupId], references: [id], onDelete: Cascade)
  priority    Int       @default(1)
  createdAt   DateTime  @default(now())

  @@map("rule_group_assignments")
}

model Leave {
  id                        String       @id @default(uuid())
  organiztionId             String
  organization              Organization @relation(fields: [organiztionId], references: [id], onDelete: Cascade)
  userId                    String
  user                      User         @relation("UserLeaves", fields: [userId], references: [id], onDelete: Cascade)
  type                      LeaveType
  startDate                 DateTime
  endDate                   DateTime
  reason                    String?
  status                    LeaveStatus  @default(PENDING) // PENDING, APPROVED, REJECTED
  approvedById              String? // Es opcional (?) porque al crearse está en PENDING y no tiene aprobador aún
  approvedBy                User?        @relation("LeavesApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  rejectionReason           String?
  emergencyCoverageRequired Boolean      @default(false)
  affectsSchedule           Boolean      @default(true)
  createdAt                 DateTime     @default(now())
  updatedAt                 DateTime     @updatedAt

  @@map("leaves")
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum LeaveType {
  MEDICAL
  SICK_LEAVE
  INJURY
  SURGERY_RECOVERY
  MATERNITY
  PATERNITY
  FAMILY_EMERGENCY
  BEREAVMENT
  ADMNISTRATIVE
  SUSPENSION
  TRAINING
  CONFERENCE
  PERSONAL
  STUDY
  RELIGIOUS
  UNPAID
}

model ActivityLog {
  id        String          @id @default(uuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    ActivityLogType // E.g., "SHIFT_APPROVED", "RULE_VIOLATED"
  details   Json // Texto JSON o descriptivo
  createdAt DateTime        @default(now())

  @@map("activity_logs")
}

enum ActivityLogType {
  LOGIN
  LOGOUT
  VIEW_SCHEDULE
  EXPORT_REPORT
  CREATE_SHIFT
  SEARCH_USER
  OPEN_NOTIFICATION
  SHIFT_APPROVED
  RULE_VIOLATED
}
